rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users collection ──
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      // ── User favorites subcollection ──
      match /favorites/{equipmentId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ── Providers collection ──
    match /providers/{providerId} {
      // Anyone authenticated can read provider profiles
      allow read: if isAuthenticated();
      // Provider can create/update their own profile
      allow create: if isAuthenticated() && isOwner(providerId);
      allow update: if isAuthenticated() && (isOwner(providerId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Equipment collection ──
    match /equipment/{equipmentId} {
      // Anyone authenticated can read equipment
      allow read: if isAuthenticated();
      // Only the equipment's provider can create
      allow create: if isAuthenticated() &&
        request.resource.data.providerId == request.auth.uid;
      // Provider can fully update/delete; any authenticated user can update availability & booking count (for booking flow)
      allow update: if isAuthenticated() &&
        (resource.data.providerId == request.auth.uid || isAdmin() ||
         // Allow booking-related fields to be updated by any authenticated user
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['availabilityStatus', 'totalBookings', 'updatedAt']) ||
         // Allow review-related fields to be updated by any authenticated user
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['rating', 'reviewCount']));
      allow delete: if isAuthenticated() &&
        (resource.data.providerId == request.auth.uid || isAdmin());
    }

    // ── Bookings collection ──
    match /bookings/{bookingId} {
      // Users can read their own bookings, providers can read bookings for their equipment
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.providerId == request.auth.uid ||
         isAdmin());
      // Any authenticated user can create a booking
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // Provider can update booking status for their equipment
      allow update: if isAuthenticated() &&
        (resource.data.providerId == request.auth.uid ||
         resource.data.userId == request.auth.uid ||
         isAdmin());
      allow delete: if isAdmin();
    }

    // ── Payments collection ──
    match /payments/{paymentId} {
      // Only involved parties or admin can read
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.providerId == request.auth.uid ||
         isAdmin());
      // System creates payments (via provider/booking service)
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Earnings collection ──
    match /earnings/{providerId} {
      // Provider can read their own earnings, admin can read all
      allow read: if isAuthenticated() &&
        (isOwner(providerId) || isAdmin());
      // System creates/updates earnings
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Reviews collection ──
    match /reviews/{reviewId} {
      // Any authenticated user can read reviews
      allow read: if isAuthenticated();
      // Authenticated user can create a review with their own userId
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // User can update/delete their own review; admin can manage all
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Platform stats (authenticated read, system write) ──
    match /platform_stats/{doc} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
